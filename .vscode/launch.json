    "version": "0.2.0",
    "configurations": [
        {
            "name": "Open Love Site",
            "request": "launch",
            "type": "chrome",
            "file": "${workspaceFolder}/Love_Site_Final.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Launch with Server (port 8080)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080/Love_Site_Final.html",
            "webRoot": "${workspaceFolder}"
        }
    ]
}